<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StudyFlow.InicioPage"
    BackgroundColor="#E8F5E9">

    <Grid>

        <VerticalStackLayout
        VerticalOptions="Center"
        HorizontalOptions="Center"
        Spacing="25"
        WidthRequest="250">

            <Image Source="ok.png"
                   HeightRequest="160"
                   Aspect="AspectFit"
                   HorizontalOptions="Center" />

            <Label Text="Bem-vindo ao StudyFlow"
               FontSize="26"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center"
               TextColor="#2E7D32" />

        <Button Text="Login" Clicked="Login_Clicked"
                BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="10" />
        
        <Button Text="Cadastrar" Clicked="Cadastrar_Clicked"
                BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="10" />

    </VerticalStackLayout>
    </Grid>
    
</ContentPage>