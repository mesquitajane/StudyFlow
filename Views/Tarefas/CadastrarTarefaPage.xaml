<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudyFlow.Views.CadastrarTarefaPage"
             BackgroundColor="#E8F5E9">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Cadastrar Tarefa"
               FontSize="24"
               FontAttributes="Bold"
               TextColor="#2E7D32"
               HorizontalOptions="Center"/>

        <Entry x:Name="entryTitulo"
               Placeholder="Título da tarefa"/>

        <Entry x:Name="entryDescricao"
               Placeholder="Descrição"/>

        <DatePicker x:Name="dateEntrega"/>
        <Entry x:Name="entryTurma"
       Placeholder="Turma (ex: 1A, 2B)" />

        <Button Text="Salvar"
                BackgroundColor="#2E7D32"
                TextColor="White"
                Clicked="OnSalvarClicked"/>

        <Button Text="Voltar"
                BackgroundColor="#2E7D32"
                TextColor="White"
                Clicked="OnVoltarClicked"/>

    </VerticalStackLayout>

</ContentPage>
