<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudyFlow.Views.Dashboards.CadastrarTarefaPage"
             BackgroundColor="#E8F5E9"
             Title="Nova Tarefa">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Image Source="ok.png" 
                       HeightRequest="80" 
                       HorizontalOptions="Center" />

                <Label Text="Cadastrar Tarefa"
                       FontSize="28"
                       TextColor="#2E7D32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <Label Text="Preencha os detalhes da atividade abaixo"
                       FontSize="14"
                       TextColor="#666"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="#2E7D32" Opacity="0.2" Margin="0,10" />

            <VerticalStackLayout Spacing="5">
                <Label Text="Título da Tarefa" TextColor="#2E7D32" FontAttributes="Bold" />
                <Entry x:Name="entryTitulo" 
                       Placeholder="Ex: Exercícios de Álgebra" 
                       TextColor="#212121" 
                       PlaceholderColor="#81C784" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Descrição (Opcional)" TextColor="#2E7D32" FontAttributes="Bold" />
                <Editor x:Name="entryDescricao" 
                        Placeholder="Descreva os detalhes, páginas do livro, etc." 
                        HeightRequest="120"
                        TextColor="#212121" 
                        PlaceholderColor="#81C784"
                        AutoSize="Disabled" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Data de Entrega" TextColor="#2E7D32" FontAttributes="Bold" />
                <DatePicker x:Name="dateEntrega" 
                            Format="dd/MM/yyyy"
                            TextColor="#212121"
                            MinimumDate="2024-01-01" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10" Margin="0,20,0,0">
                <Button Text="SALVAR TAREFA" 
                        Clicked="OnSalvarClicked"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        CornerRadius="10"/>

                <Button Text="CANCELAR" 
                        Clicked="OnVoltarClicked"
                        BackgroundColor="Transparent"
                        TextColor="#2E7D32"
                        FontAttributes="Bold"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>