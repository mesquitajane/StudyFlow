<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudyFlow.Views.Dashboards.SecretariaDashboard"
             BackgroundColor="#E8F5E9">

    <Grid RowDefinitions="Auto, *" Padding="20">
        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,0,0,20">
            <Label Text="Painel Administrativo" FontSize="24" FontAttributes="Bold" TextColor="#2E7D32"/>
            <Label x:Name="lblInfo" Text="Operador: Secretaria" FontSize="14" TextColor="#666"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="10">
                <Button Text="Gerenciar Usuários" BackgroundColor="#2E7D32" TextColor="White"/>
                <Button Text="Matrículas e Turmas" BackgroundColor="#2E7D32" TextColor="White"/>
                <Button Text="Emitir Relatórios Gerais" BackgroundColor="#2E7D32" TextColor="White"/>
                <Button Text="Configurações do Sistema" BackgroundColor="#2E7D32" TextColor="White"/>
                <Button Text="Sair" Clicked="OnSairClicked" BackgroundColor="#C62828" TextColor="White" Margin="0,20,0,0"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>