
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudyFlow.LoginPage"
             BackgroundColor="#E8F5E9">

    <VerticalStackLayout Padding="30" Spacing="15">

        <Image Source="ok.png"
               HeightRequest="130"
               Aspect="AspectFit"
               HorizontalOptions="Center" />

        <Label Text="StudyFlow"
               FontSize="32"
               HorizontalOptions="Center"
               TextColor="#2E7D32"
               FontAttributes="Bold"/>

        <Entry x:Name="entryEmail"
               Placeholder="E-mail"
               Keyboard="Email"
               TextColor="#212121" 
               PlaceholderColor="#81C784"/>

        <Entry x:Name="entrySenha"
               Placeholder="Senha"
               IsPassword="True"
               TextColor="#212121"
               PlaceholderColor="#81C784"/>
        
        <Button Text="Entrar" Clicked="OnLoginClicked"
                BackgroundColor="#2E7D32"
                TextColor="White"/>

        <Label x:Name="lblErro"
               TextColor="Red"
               IsVisible="False"
               HorizontalOptions="Center"/>

        <Button Text="Voltar" Clicked="Button_Clicked"
            BackgroundColor="#2E7D32"
                TextColor="White"/>

    </VerticalStackLayout>

</ContentPage>